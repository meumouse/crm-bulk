# Base
RD_BASE_URL=https://api.rd.services

# Option A (simplest): one-off access token (no refresh)
RD_ACCESS_TOKEN=YOUR_ACCESS_TOKEN

# Option B (recommended): OAuth refresh flow (requires oauth token JSON file)
RD_CLIENT_ID=YOUR_CLIENT_ID
RD_CLIENT_SECRET=YOUR_CLIENT_SECRET
RD_TOKEN_URL=https://api.rd.services/oauth2/token
RD_OAUTH_STATE_FILE=oauth_token.json

# Runtime
REQUEST_DELAY_MS=250
MAX_RETRIES=5
DRY_RUN=true
VERIFY_AFTER_UPDATE=false

# Behavior
PIPELINE_ATUAL_INCLUDE_FUNIL=false
MERGE_MULTI_SELECT=true

# Pagination (fallbacks supported: jsonapi | page_limit)
PAGINATION_MODE=jsonapi
PAGE_SIZE=50
